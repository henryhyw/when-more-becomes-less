# Reproducibility pipeline for
#   "When More Becomes Less: A Two-Probe Diagnostic for Repetition in
#    Language Models"
#
# Two stages:
#   Stage 1 — data generation (GPU, ~8–12 h on A100):
#               code/notebooks/full_paper_pipeline.ipynb
#   Stage 2 — figures (CPU, <1 min): code/src/make_figures.py
#
# Targets:
#   make data         run the data-generation notebook (requires GPU + jupyter)
#   make figures      regenerate the four data-driven paper figures
#   make clean        remove regenerated figures

PYTHON  ?= python3
JUPYTER ?= jupyter

# Run from repo root, e.g.:
#   make -C code data
#   make -C code figures

# Figure 1 (probe schematic) is a hand-authored static asset, not
# regenerated by the pipeline. It ships in data/figures/.
FIGS    := ../data/figures

PAPER_FIG_TARGETS := \
  $(FIGS)/fig2_main_curves.pdf \
  $(FIGS)/fig3_ablation.pdf \
  $(FIGS)/fig4_mechanism.pdf \
  $(FIGS)/fig_layerwise_mechanism.pdf

.PHONY: help data figures clean

help:
	@echo "make data       - run notebooks/full_paper_pipeline.ipynb (GPU required)"
	@echo "make figures    - regenerate the four data-driven figures"
	@echo "make clean      - remove regenerated figures (fig1 is static, preserved)"

# ---------------------------------------------------------------------------
# Stage 1 — data generation (GPU)
# ---------------------------------------------------------------------------
data:
	$(JUPYTER) nbconvert --to notebook --execute --inplace \
	  notebooks/full_paper_pipeline.ipynb

# ---------------------------------------------------------------------------
# Stage 2 — figures (CPU)
# ---------------------------------------------------------------------------
figures: $(PAPER_FIG_TARGETS)

$(PAPER_FIG_TARGETS): src/make_figures.py
	$(PYTHON) src/make_figures.py

# ---------------------------------------------------------------------------
# Cleanup
# ---------------------------------------------------------------------------
clean:
	-rm -f $(PAPER_FIG_TARGETS)
	# fig1 is a static asset and is intentionally NOT removed by clean.
